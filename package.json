{
  "name": "@towles/tool",
  "version": "0.0.114",
  "description": "One off quality of life scripts that I use on a daily basis.",
  "homepage": "https://github.com/ChrisTowles/towles-tool#readme",
  "bugs": {
    "url": "https://github.com/ChrisTowles/towles-tool/issues"
  },
  "license": "MIT",
  "author": "Chris Towles <Chris.Towles.Dev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChrisTowles/towles-tool.git"
  },
  "funding": {
    "url": "https://github.com/sponsors/ChrisTowles"
  },
  "bin": {
    "towles-tool": "./bin/run.ts",
    "tt": "./bin/run.ts"
  },
  "workspaces": [
    "packages/*",
    "packages/agentboard/apps/*",
    "packages/agentboard/packages/*"
  ],
  "files": [
    "bin",
    "packages",
    "patches",
    "src"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "version:sync": "bun run scripts/sync-versions.ts",
    "prepublishOnly": "bun run version:sync",
    "dev": "bun run bin/run.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "CI=DisableCallingClaude vitest watch",
    "typecheck": "tsgo --noEmit --incremental",
    "link": "bun link",
    "link:show": "readlink -f $(which towles-tool)",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.4",
    "@anthropic-ai/sdk": "^0.56.0",
    "@towles/shared": "workspace:*",
    "citty": "^0.1.6",
    "consola": "^3.4.2",
    "d3-hierarchy": "^3.1.2",
    "fzf": "^0.5.2",
    "luxon": "^3.7.1",
    "neverthrow": "^8.2.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/luxon": "^3.6.2",
    "@types/node": "^22.16.3",
    "@types/prompts": "^2.4.9",
    "@typescript/native-preview": "^7.0.0-dev.20260111.1",
    "bumpp": "^10.4.0",
    "oxfmt": "^0.24.0",
    "oxlint": "^1.7.0",
    "simple-git-hooks": "^2.13.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.17"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run format && bun run lint:fix && bun run typecheck && claude plugin validate ."
  },
  "patchedDependencies": {
    "prompts@2.4.2": "patches/prompts.patch"
  },
  "trustedDependencies": [
    "@anthropic-ai/claude-code"
  ]
}
