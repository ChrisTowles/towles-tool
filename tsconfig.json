{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "strictNullChecks": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "types": ["node", "@types/bun"],
    "paths": {
      "@towles/shared": ["./packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "bin/**/*.ts", "scripts/**/*.ts", "packages/shared/src/**/*.ts"],
  "exclude": ["packages/agentboard"]
}
